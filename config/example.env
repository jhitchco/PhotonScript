# PhotonScript Configuration
# Copy to .env and customize for your setup

# --- Observatory Location ---
PS_OBSERVATORY_NAME="AARO Pier 3 (Rodeo, NM)"
PS_OBSERVATORY_LAT=31.906944
PS_OBSERVATORY_LON=-109.021367
PS_OBSERVATORY_ELEV=1250
PS_OBSERVATORY_TZ="America/Denver"
PS_OBSERVATORY_BORTLE=2

# --- Scheduler ---
PS_SCHEDULER_HOST=0.0.0.0
PS_SCHEDULER_PORT=8100
PS_LOG_LEVEL=INFO

# --- NINA (on Windows telescope PC) ---
PS_NINA_BASE_URL="http://localhost:1888/v2/api"
PS_IMAGE_WATCH_DIR="C:\\Users\\jeremy\\Documents\\N.I.N.A"
PS_NINA_LOGS_DIR="C:\\Users\\jeremy\\AppData\\Local\\NINA\\Logs"

# --- PHD2 Guiding ---
PS_PHD2_HOST=localhost
PS_PHD2_PORT=4400

# --- Image Quality Thresholds ---
PS_QUALITY_FWHM_MAX=4.0
PS_QUALITY_ECCENTRICITY_MAX=0.6
PS_QUALITY_TRACKING_RMS_MAX=2.0
PS_CAMERA_READ_NOISE_ADU=4.1

# --- Librarian / Transfers ---
# SSH to remote telescope PC (leave empty for local/network share)
PS_TRANSFER_HOST=""
PS_TRANSFER_PORT=22
PS_TRANSFER_USER=""
PS_TRANSFER_KEY_PATH=""

# Transfer window (daytime only for Starlink bandwidth)
PS_TRANSFER_START_HOUR=8
PS_TRANSFER_END_HOUR=18
PS_TRANSFER_BANDWIDTH_LIMIT_MBPS=50

# Local paths
PS_REMOTE_IMAGE_DIR="C:\\Astrophotography"
PS_LOCAL_IMAGE_DIR="~/Astrophotography"
PS_STACKING_OUTPUT_DIR="~/Astrophotography/Processed"

# --- Processing ---
PS_SIRIL_PATH="siril-cli"
PS_PIXINSIGHT_PATH=""

# --- AstroBin (optional) ---
PS_ASTROBIN_API_KEY=""
PS_ASTROBIN_API_SECRET=""

# --- AARO Imaging Defaults ---
PS_DEFAULT_GAIN=200
PS_DEFAULT_OFFSET=256
PS_CAMERA_SETPOINT_C=0.0
PS_GUIDED_DEFAULT=true
PS_PIXEL_SCALE_ARCSEC=0.24

# --- Supervisor / Nanny ---
PS_PUSHOVER_USER_KEY=
PS_PUSHOVER_API_TOKEN=
PS_CONSECUTIVE_REJECT_LIMIT=3
PS_AUTO_ABORT_ON_SEVERE=false
PS_HEARTBEAT_MINUTES=30
